# Chronicle Mind — Environment Variables
# Rename this file to .env and fill in your key.
# Vite exposes variables prefixed with VITE_ to the browser bundle.

# Groq API Key (free at https://console.groq.com)
# Used ONLY for audio transcription via Whisper.
# Text mode works without any key.
VITE_GROQ_API_KEY=your_groq_api_key_here

# Firebase (Google Sign-In)
# Create a project at https://console.firebase.google.com
# → Authentication → Sign-in method → Enable Google
# → Project Settings → Your apps → Add web app → copy config values
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
